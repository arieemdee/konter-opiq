<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ringkasan Laporan</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 font-sans text-gray-800">
    <div class="container mx-auto p-6 max-w-7xl">
        <header class="bg-violet-600 text-white p-6 rounded-lg shadow-md mb-6 flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold">RINGKASAN LAPORAN BULANAN</h1>
                <p class="text-violet-100 text-sm mt-1">Total penjualan, produk terlaris, dan omzet harian dalam satu tampilan</p>
            </div>
            <div class="bg-violet-700 px-4 py-2 rounded text-right">
                <span class="text-xs block text-violet-200">Total Penjualan</span>
                <span class="text-xl font-bold">Rp <%= grandTotal %>.000</span>
            </div>
        </header>

        <div class="bg-white p-4 rounded-lg shadow-md flex flex-wrap items-center justify-between gap-4 border-t-4 border-violet-500 mb-6">
            <div class="flex items-center gap-2">
                <span class="text-lg">📅</span>
                <h3 class="font-bold text-gray-700 text-xs uppercase tracking-wider">Filter Periode</h3>
            </div>
            <form action="/laporan-summary" method="GET" class="flex flex-wrap items-center gap-3 text-xs">
                <div class="flex items-center gap-2">
                    <label class="font-semibold text-gray-500">Dari:</label>
                    <input type="month" name="bulanAwal" value="<%= filterBulanAwal %>" class="p-1.5 border rounded bg-gray-50 focus:ring-1 focus:ring-violet-400 font-medium">
                </div>
                <div class="flex items-center gap-2">
                    <label class="font-semibold text-gray-500">Sampai:</label>
                    <input type="month" name="bulanAkhir" value="<%= filterBulanAkhir %>" class="p-1.5 border rounded bg-gray-50 focus:ring-1 focus:ring-violet-400 font-medium">
                </div>
                <div class="flex gap-1 pl-2">
                    <button type="submit" class="bg-violet-600 text-white px-4 py-1.5 rounded font-bold hover:bg-violet-700 transition shadow-sm">Terapkan</button>
                    <a href="/laporan-summary" class="bg-gray-500 text-white px-3 py-1.5 rounded font-bold hover:bg-gray-600 transition shadow-sm text-center">Bulan Ini</a>
                    <a href="/" class="bg-blue-600 text-white px-3 py-1.5 rounded font-bold hover:bg-blue-700 transition shadow-sm text-center">Kembali ke Laporan</a>
                </div>
            </form>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
            <div class="bg-white p-5 rounded-lg shadow-md border-l-4 border-emerald-500">
                <p class="text-sm text-gray-500">Total Penjualan</p>
                <p class="text-2xl font-bold text-emerald-700">Rp <%= summary.totalPenjualan %>.000</p>
            </div>
            <div class="bg-white p-5 rounded-lg shadow-md border-l-4 border-blue-500">
                <p class="text-sm text-gray-500">Produk Terlaris</p>
                <p class="text-2xl font-bold text-blue-700"><%= summary.produkTerlaris.nama %></p>
                <p class="text-sm text-gray-500">Terjual <%= summary.produkTerlaris.terjual %> unit</p>
            </div>
            <div class="bg-white p-5 rounded-lg shadow-md border-l-4 border-amber-500">
                <p class="text-sm text-gray-500">Omzet Harian</p>
                <p class="text-2xl font-bold text-amber-700"><%= summary.dailyChart.length %> Hari</p>
                <p class="text-sm text-gray-500">Data harian terhitung dari transaksi</p>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            <div class="bg-white p-6 rounded-lg shadow-md">
                <h2 class="text-lg font-bold text-gray-700 mb-4">📊 Ringkasan Bulanan</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-gray-100 text-gray-600 uppercase text-xs">
                                <th class="p-2 text-left">Periode</th>
                                <th class="p-2 text-right">Transaksi</th>
                                <th class="p-2 text-right">Omzet</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% summary.monthlyRows.forEach(row => { %>
                                <tr class="border-b">
                                    <td class="p-2 font-semibold"><%= row.label %></td>
                                    <td class="p-2 text-right"><%= row.transaksi %></td>
                                    <td class="p-2 text-right font-bold text-emerald-700">Rp <%= row.omzet %>.000</td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md">
                <h2 class="text-lg font-bold text-gray-700 mb-4">📈 Grafik Omzet Harian</h2>
                <div class="space-y-3">
                    <% summary.dailyChart.forEach(item => { %>
                        <div>
                            <div class="flex justify-between text-xs text-gray-500 mb-1">
                                <span><%= item.label %></span>
                                <span>Rp <%= item.omzet %>.000</span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-2.5">
                                <div class="bg-violet-600 h-2.5 rounded-full" style="width: <%= Math.min(100, Math.max(8, item.omzet / Math.max(1, summary.totalPenjualan) * 100)) %>%;"></div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</body>
</html>