<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pembukuan Konter Opiq</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 font-sans text-gray-800">

    <div class="container mx-auto p-6 max-w-7xl">
        <!-- Header -->
        <header class="bg-blue-600 text-white p-6 rounded-lg shadow-md mb-6 flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold">REKAP PEMBUKUAN KONTER OPIQ</h1>
                <p class="text-blue-100 text-sm mt-1">Sistem Otomatisasi Stok Penjualan Pulsa & Aksesoris</p>
            </div>
            <div class="bg-blue-700 px-4 py-2 rounded text-right">
                <span class="text-xs block text-blue-200">Total Pendapatan Terfilter</span>
                <span class="text-xl font-bold">Rp <%= grandTotal %>.000</span>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- SISI KIRI: INPUT DATA -->
            <div class="bg-white p-6 rounded-lg shadow-md h-fit">
                <h2 class="text-xl font-bold border-b pb-2 mb-4 text-gray-700">Form Input Harian</h2>
                <form action="/tambah-transaksi" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">Pilih Produk / Item</label>
                        <select name="produk" required class="w-full p-2 border rounded bg-gray-50 focus:ring-2 focus:ring-blue-400">
                            <% for (const [kategori, sub] of Object.entries(katalog)) { %>
                                <optgroup label="--- <%= kategori %> ---">
                                    <% for (const [brand, list] of Object.entries(sub)) { %>
                                        <% list.forEach(p => { %>
                                            <option value="<%= brand %> - <%= p %>"><%= brand %> - <%= p %></option>
                                        <% }) %>
                                    <% } %>
                                </optgroup>
                            <% } %>
                        </select>
                    </div>

                    <div class="grid grid-cols-3 gap-2">
                        <div>
                            <label class="block text-xs font-medium text-gray-500 mb-1">Stok Awal (AW)</label>
                            <input type="number" name="aw" min="0" value="0" class="w-full p-2 border rounded focus:ring-2 focus:ring-blue-400">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-500 mb-1">Tambah (TB)</label>
                            <input type="number" name="tb" min="0" value="0" class="w-full p-2 border rounded focus:ring-2 focus:ring-blue-400">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-500 mb-1">Akhir (AH)</label>
                            <input type="number" name="ah" min="0" value="0" class="w-full p-2 border rounded focus:ring-2 focus:ring-blue-400" required>
                        </div>
                    </div>

                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 rounded transition shadow">
                        Simpan Transaksi
                    </button>
                </form>

                <!-- FITUR FILTER & TUTUP BUKU -->
                <div class="mt-8 pt-6 border-t border-gray-200">
                    <h3 class="font-bold text-gray-700 mb-2">Filter & Manajemen Bulanan</h3>
                    
                    <!-- Form Filter -->
                    <form action="/" method="GET" class="flex gap-2 mb-4">
                        <input type="month" name="bulan" value="<%= filterBulan %>" class="p-2 border rounded text-sm w-full">
                        <button type="submit" class="bg-gray-700 text-white px-4 py-2 rounded text-sm hover:bg-gray-800">Filter</button>
                        <% if(filterBulan) { %>
                            <a href="/" class="bg-red-500 text-white px-3 py-2 rounded text-sm flex items-center">Reset</a>
                        <% } %>
                    </form>

                    <!-- Form Tutup Buku -->
                    <% if(filterBulan) { %>
                        <form action="/tutup-buku" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin melakukan Tutup Buku untuk bulan ini? Semua transaksi bulan ini akan dikunci dan tidak bisa diubah.')">
                            <input type="hidden" name="bulanTutup" value="<%= filterBulan %>">
                            <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white text-sm font-semibold py-2 rounded transition">
                                🔒 Tutup Buku Bulan <%= filterBulan %>
                            </button>
                        </form>
                    <% } else { %>
                        <p class="text-xs text-red-500 italic bg-red-50 p-2 rounded text-center">Silakan pilih/filter bulan terlebih dahulu untuk mengaktifkan fitur Tutup Buku Akhir Bulan.</p>
                    <% } %>
                </div>
            </div>

            <!-- SISI KANAN: TABEL REKAP/TRANSAKSI (MEMAKAN 2 KOLOM) -->
            <div class="bg-white p-6 rounded-lg shadow-md lg:col-span-2 overflow-x-auto">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold text-gray-700">
                        Daftar Laporan Penjualan <%= filterBulan ? `(${filterBulan})` : '(Semua Waktu)' %>
                    </h2>
                    <span class="text-xs text-gray-500">Keterangan: <b class="text-blue-600">AW</b> (Awal) | <b class="text-blue-600">TB</b> (Tambah) | <b class="text-blue-600">TTL</b> (Total) | <b class="text-blue-600">AH</b> (Akhir) | <b class="text-blue-600">TR</b> (Terjual)</span>
                </div>

                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-gray-100 text-gray-600 uppercase text-xs border-b">
                            <th class="p-3">Tanggal</th>
                            <th class="p-3">Item/Produk</th>
                            <th class="p-3 text-center">AW</th>
                            <th class="p-3 text-center">TB</th>
                            <th class="p-3 text-center">TTL</th>
                            <th class="p-3 text-center">AH</th>
                            <th class="p-3 text-center bg-blue-50 text-blue-700">TR</th>
                            <th class="p-3 text-right">Harga</th>
                            <th class="p-3 text-right bg-green-50 text-green-700 font-bold">Total (JML)</th>
                            <th class="p-3 text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y">
                        <% if (transaksi.length === 0) { %>
                            <tr>
                                <td colspan="10" class="p-8 text-center text-gray-400 italic">Belum ada data penjualan tercatat.</td>
                            </tr>
                        <% } else { %>
                            <% transaksi.forEach(t => { %>
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="p-3 text-xs whitespace-nowrap"><%= t.tanggal %></td>
                                    <td class="p-3 font-medium text-gray-900"><%= t.produk %></td>
                                    <td class="p-3 text-center text-gray-600"><%= t.aw %></td>
                                    <td class="p-3 text-center text-gray-600"><%= t.tb %></td>
                                    <td class="p-3 text-center text-gray-600"><%= t.ttl %></td>
                                    <td class="p-3 text-center text-gray-600"><%= t.ah %></td>
                                    <td class="p-3 text-center bg-blue-50 text-blue-700 font-semibold"><%= t.tr %></td>
                                    <td class="p-3 text-right text-gray-600">Rp <%= t.harga %>.000</td>
                                    <td class="p-3 text-right bg-green-50 text-green-700 font-bold">Rp <%= t.jml %>.000</td>
                                    <td class="p-3 text-center">
                                        <span class="px-2 py-0.5 text-xs rounded-full <%= t.status === 'Aktif' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                                            <%= t.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</body>
</html>