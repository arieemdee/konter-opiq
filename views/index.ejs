<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pembukuan Konter Opiq</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 font-sans text-gray-800">

    <div class="container mx-auto p-6 max-w-7xl">
        <header class="bg-blue-600 text-white p-6 rounded-lg shadow-md mb-6 flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold">REKAP PEMBUKUAN KONTER</h1>
                <p class="text-blue-100 text-sm mt-1">Sistem Otomatisasi Stok Penjualan Pulsa & Aksesoris</p>
            </div>
            <div class="bg-blue-700 px-4 py-2 rounded text-right">
                <span class="text-xs block text-blue-200">Total Pendapatan Terfilter</span>
                <span class="text-xl font-bold">Rp <%= grandTotal %>.000</span>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- SISI KIRI: FORMS UTAMA -->
            <div class="space-y-6">
                <!-- FORM INPUT -->
                <div class="bg-white p-6 rounded-lg shadow-md border-t-4 border-blue-500">
                    <h2 class="text-lg font-bold border-b pb-2 mb-4 text-gray-700">Form Input Harian</h2>
                    <form action="/tambah-transaksi" method="POST" class="space-y-4">
                        <div>
                            <!-- LABEL DAN TOMBOL MODAL KATALOG DIBUAT SEJAJAR -->
                            <div class="flex justify-between items-center mb-1">
                                <label class="block text-xs font-medium text-gray-600">Pilih Produk</label>
                                <button type="button" onclick="bukaModalKatalog()" class="bg-emerald-100 hover:bg-emerald-200 text-emerald-700 px-2 py-0.5 rounded text-[10px] font-bold shadow-sm transition border border-emerald-200">
                                    + Tambah Katalog
                                </button>
                            </div>
                            <select name="produk" id="produkSelect" required class="w-full p-2 border rounded bg-gray-50 focus:ring-2 focus:ring-blue-400 text-sm">
                                <% for (const [kategori, sub] of Object.entries(katalog)) { %>
                                    <optgroup label="--- <%= kategori %> ---">
                                        <% for (const [brand, list] of Object.entries(sub)) { %>
                                            <% list.forEach(p => { %>
                                                <option value="<%= brand %> - <%= p %>"><%= brand %> - <%= p %></option>
                                            <% }) %>
                                        <% } %>
                                    </optgroup>
                                <% } %>
                            </select>
                        </div>
                        <div class="grid grid-cols-3 gap-2">
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1 text-blue-600 font-bold">Awal (AW)</label>
                                <input type="number" name="aw" id="stokAwalInput" min="0" value="0" class="w-full p-2 border rounded bg-yellow-50 font-bold">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">Tambah (TB)</label>
                                <input type="number" name="tb" min="0" value="0" class="w-full p-2 border rounded">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1 text-red-600 font-bold">Sisa (AH)</label>
                                <input type="number" name="ah" min="0" value="0" class="w-full p-2 border rounded bg-red-50 font-bold" required>
                            </div>
                        </div>
                        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 rounded text-sm shadow">
                            Simpan Transaksi
                        </button>
                    </form>
                </div>

                <!-- FORM TUTUP BUKU -->
                <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-red-500">
                    <div class="flex justify-between items-center mb-2">
                        <h3 class="font-bold text-gray-700 text-sm">🔒 Kunci Buku Bulanan</h3>
                        <!-- Tombol Help Baru -->
                        <button type="button" onclick="bukaModalInfoBuku()" class="text-[10px] bg-red-100 text-red-600 rounded-full w-5 h-5 flex items-center justify-center font-bold hover:bg-red-200">
                            ?
                        </button>
                    </div>
                    <form action="/tutup-buku" method="POST" onsubmit="return confirm('Kunci semua transaksi pada bulan terpilih? Data tidak akan bisa di-edit/hapus lagi!')" class="space-y-2">
                        <div>
                            <label class="block text-[10px] uppercase font-bold text-gray-400 mb-1">Pilih Bulan Yang Akan Dikunci</label>
                            <input type="month" name="bulanTutup" required class="p-2 border rounded text-xs w-full bg-red-50/50">
                        </div>
                        <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white text-xs font-bold py-2 rounded transition shadow-sm">
                            Kunci Transaksi Bulan Ini
                        </button>
                    </form>
                </div>
            </div>

            <!-- SISI KANAN: FILTER & TABEL TRANSAKSI -->
            <div class="space-y-4 lg:col-span-2">
                
                <!-- FILTER RENTANG WAKTU HORIZONTAL -->
                <div class="bg-white p-4 rounded-lg shadow-md flex flex-wrap items-center justify-between gap-4 border-t-4 border-blue-500">
                    <div class="flex items-center gap-2">
                        <span class="text-lg">📅</span>
                        <h3 class="font-bold text-gray-700 text-xs uppercase tracking-wider">Rentang Laporan</h3>
                    </div>
                    <form action="/" method="GET" class="flex flex-wrap items-center gap-3 text-xs">
                        <div class="flex items-center gap-2">
                            <label class="font-semibold text-gray-500">Dari:</label>
                            <input type="month" name="bulanAwal" value="<%= filterBulanAwal %>" class="p-1.5 border rounded bg-gray-50 focus:ring-1 focus:ring-blue-400 font-medium">
                        </div>
                        <div class="flex items-center gap-2">
                            <label class="font-semibold text-gray-500">Sampai:</label>
                            <input type="month" name="bulanAkhir" value="<%= filterBulanAkhir %>" class="p-1.5 border rounded bg-gray-50 focus:ring-1 focus:ring-blue-400 font-medium">
                        </div>
                        <div class="flex gap-1 pl-2">
                            <button type="submit" class="bg-blue-600 text-white px-4 py-1.5 rounded font-bold hover:bg-blue-700 transition shadow-sm">Terapkan</button>
                            <a href="/" class="bg-gray-500 text-white px-3 py-1.5 rounded font-bold hover:bg-gray-600 transition shadow-sm text-center">Bulan Ini</a>
                        </div>
                    </form>
                </div>

                <!-- TABEL LAPORAN PENJUALAN -->
                <div class="bg-white p-6 rounded-lg shadow-md overflow-x-auto">
                    <div class="flex flex-wrap items-center justify-between mb-4 gap-2">
                        <div class="flex items-center gap-2">
                            <h2 class="text-xl font-bold text-gray-700">Laporan Penjualan</h2>
                            <button onclick="bukaModalBantuan()" class="bg-blue-100 hover:bg-blue-200 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold shadow-sm transition" title="Klik untuk melihat arti singkatan tabel">
                                ?
                            </button>
                        </div>
                        <div class="text-xs bg-blue-50 text-blue-700 font-semibold px-2.5 py-1 rounded border border-blue-100">
                            Periode: <%= filterBulanAwal || 'Mulai Awal' %> s/d <%= filterBulanAkhir || 'Sekarang' %>
                        </div>
                    </div>
                    
                    <table class="w-full text-left border-collapse text-xs">
                        <thead>
                            <tr class="bg-gray-100 text-gray-600 uppercase border-b">
                                <th class="p-3">Tanggal</th>
                                <th class="p-3">Produk</th>
                                <th class="p-3 text-center">AW</th>
                                <th class="p-3 text-center">TB</th>
                                <th class="p-3 text-center">TTL</th>
                                <th class="p-3 text-center">AH</th>
                                <th class="p-3 text-center bg-blue-50 text-blue-700">TR</th>
                                <th class="p-3 text-right font-bold bg-green-50 text-green-700">JML</th>
                                <th class="p-3 text-center">Status</th>
                                <th class="p-3 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y">
                            <% if (transaksi.length === 0) { %>
                                <tr><td colspan="10" class="p-8 text-center text-gray-400 italic">Tidak ada transaksi ditemukan.</td></tr>
                            <% } else { %>
                                <% transaksi.forEach(t => { %>
                                    <tr class="hover:bg-gray-50 transition">
                                        <td class="p-3 text-xs whitespace-nowrap"><%= t.tanggal %></td>
                                        <td class="p-3 font-medium text-gray-900"><%= t.produk %></td>
                                        <td class="p-3 text-center text-gray-600"><%= t.aw %></td>
                                        <td class="p-3 text-center text-gray-600"><%= t.tb %></td>
                                        <td class="p-3 text-center text-gray-600"><%= t.ttl %></td>
                                        <td class="p-3 text-center text-gray-600"><%= t.ah %></td>
                                        <td class="p-3 text-center bg-blue-50 text-blue-700 font-semibold"><%= t.tr %></td>
                                        <td class="p-3 text-right bg-green-50 text-green-700 font-bold">Rp <%= t.jml %>.000</td>
                                        <td class="p-3 text-center">
                                            <span class="px-2 py-0.5 text-[10px] rounded-full <%= t.status === 'Aktif' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>"><%= t.status %></span>
                                        </td>
                                        <td class="p-3 text-center flex justify-center gap-1">
                                            <% if(t.status === 'Aktif') { %>
                                                <button onclick="bukaModalEdit(<%= t.id %>, '<%= t.produk %>', <%= t.aw %>, <%= t.tb %>, <%= t.ah %>)" class="bg-yellow-400 hover:bg-yellow-500 text-white px-2 py-1 rounded shadow-sm text-[10px] font-bold">Edit</button>
                                                <button onclick="hapusTransaksi(<%= t.id %>)" class="bg-red-500 hover:bg-red-600 text-white px-2 py-1 rounded shadow-sm text-[10px] font-bold">Del</button>
                                            <% } else { %>
                                                <span class="text-[10px] text-gray-400 italic">Terkunci</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                        
                        <% if (transaksi.length > 0) { %>
                            <tfoot class="border-t-2 border-gray-300">
                                <tr class="bg-gray-50 font-bold text-gray-700">
                                    <td colspan="7" class="p-3 text-right uppercase text-xs tracking-wider">Sub Total / Total Terfilter:</td>
                                    <td class="p-3 text-right bg-green-100 text-green-800 font-extrabold text-sm whitespace-nowrap">Rp <%= grandTotal %>.000</td>
                                    <td colspan="2" class="p-3 bg-gray-50"></td>
                                </tr>
                            </tfoot>
                        <% } %>
                    </table>

                    <!-- NAVIGASI PAGINASI -->
                    <% if (totalPages > 1) { %>
                        <div class="mt-6 flex justify-center items-center gap-2">
                            <!-- Tombol Previous -->
                            <% if (currentPage > 1) { %>
                                <a href="/?bulanAwal=<%= filterBulanAwal %>&bulanAkhir=<%= filterBulanAkhir %>&page=<%= currentPage - 1 %>" class="px-3 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300 font-bold">Previous</a>
                            <% } %>

                            <!-- List Halaman -->
                            <% for(let i = 1; i <= totalPages; i++) { %>
                                <a href="/?bulanAwal=<%= filterBulanAwal %>&bulanAkhir=<%= filterBulanAkhir %>&page=<%= i %>" 
                                class="px-3 py-1 rounded text-xs font-bold <%= currentPage === i ? 'bg-blue-600 text-white' : 'bg-gray-100 hover:bg-blue-100' %>">
                                    <%= i %>
                                </a>
                            <% } %>

                            <!-- Tombol Next -->
                            <% if (currentPage < totalPages) { %>
                                <a href="/?bulanAwal=<%= filterBulanAwal %>&bulanAkhir=<%= filterBulanAkhir %>&page=<%= currentPage + 1 %>" class="px-3 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300 font-bold">Next</a>
                            <% } %>
                        </div>
                    <% } %>
                </div>

                <!-- DAFTAR KATALOG -->
                <div class="bg-white p-6 rounded-lg shadow-md border-t-4 border-gray-300">
                    <h3 class="text-base font-bold text-gray-700 mb-3 border-b pb-2">📋 Laporan Data Produk Aktif (Bisa Dihapus)</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-40 overflow-y-auto pr-2 text-xs">
                        <% for (const [kategori, sub] of Object.entries(katalog)) { %>
                            <div class="bg-gray-50 p-3 rounded border">
                                <h4 class="font-bold text-blue-600 mb-1 text-xs"><%= kategori %></h4>
                                <% for (const [brand, list] of Object.entries(sub)) { %>
                                    <div class="ml-2 mb-2">
                                        <span class="font-semibold text-gray-700 bg-gray-200 px-1.5 py-0.5 rounded text-[10px]"><%= brand %></span>
                                        <ul class="mt-1 space-y-1 ml-1">
                                            <% list.forEach(p => { %>
                                                <li class="flex justify-between items-center bg-white p-1 rounded border shadow-sm">
                                                    <span><%= p %></span>
                                                    <button onclick="hapusKatalog('<%= kategori %>', '<%= brand %>', '<%= p %>')" class="text-red-500 hover:text-red-700 font-bold px-1 hover:bg-red-50 rounded" title="Hapus Produk">✕</button>
                                                </li>
                                            <% }) %>
                                        </ul>
                                    </div>
                                <% } %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

        </div>
        <footer class="mt-4 text-center text-muted small">
            <div class="border-top pt-3">
                <p class="mb-1">Dibuat oleh <strong>MD Engine</strong></p>
                <a href="https://md-engine.com" target="_blank" rel="noopener noreferrer" class="text-decoration-none">md-engine.com</a>
            </div>
        </footer>
    </div>

    <!-- ============================================== -->
    <!-- MODAL TAMBAH KATALOG BARU -->
    <!-- ============================================== -->
    <div id="modalKatalog" class="fixed inset-0 bg-black/60 hidden flex items-center justify-center z-50">
        <div class="bg-white p-6 rounded-lg w-[450px] shadow-2xl">
            <div class="flex justify-between items-center mb-4 border-b pb-2">
                <h2 class="text-lg font-bold text-emerald-700 flex items-center gap-2">
                    ⚙️ Tambah Katalog Produk
                </h2>
                <button type="button" onclick="tutupModalKatalog()" class="text-gray-400 hover:text-red-600 text-2xl font-bold leading-none" title="Tutup Modal">&times;</button>
            </div>
            <form action="/katalog/tambah" method="POST" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-gray-600 mb-1">Pilih Kategori</label>
                    <select name="kategori" class="w-full p-2 border rounded text-sm bg-gray-50">
                        <option value="DATA UTAMA">DATA UTAMA</option>
                        <option value="DATA MINI / MINGGUAN">DATA MINI / MINGGUAN</option>
                        <option value="DATA BULANAN">DATA BULANAN</option>
                        <option value="AKSESORIS">AKSESORIS</option>
                    </select>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-bold text-gray-600 mb-1">Brand</label>
                        <input type="text" name="brand" placeholder="Cth: TELKOMSEL" required class="w-full p-2 border rounded text-sm uppercase">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-600 mb-1">Harga (Ribuan)</label>
                        <input type="number" name="harga_k" placeholder="Cth: 30" required class="w-full p-2 border rounded text-sm bg-blue-50">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-600 mb-1">Varian / Nama Item</label>
                    <input type="text" name="nama_item" placeholder="Cth: S 6GB" required class="w-full p-2 border rounded text-sm">
                </div>
                <div class="flex justify-end gap-2 mt-6 pt-4 border-t">
                    <button type="button" onclick="tutupModalKatalog()" class="bg-gray-400 hover:bg-gray-500 text-white px-4 py-2 rounded text-sm font-semibold shadow-sm transition">Batal</button>
                    <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded text-sm font-bold shadow-sm transition">Simpan ke Katalog</button>
                </div>
            </form>
        </div>
    </div>

    <!-- ============================================== -->
    <!-- MODAL BANTUAN SINGKATAN -->
    <!-- ============================================== -->
    <div id="modalBantuan" class="fixed inset-0 bg-black/60 hidden flex items-center justify-center z-50">
        <div class="bg-white p-6 rounded-lg w-[400px] shadow-2xl">
            <div class="flex justify-between items-center mb-4 border-b pb-2">
                <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                    <span class="bg-blue-100 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold">?</span>
                    Bantuan Singkatan
                </h2>
                <button onclick="tutupModalBantuan()" class="text-gray-400 hover:text-red-600 text-2xl font-bold leading-none">&times;</button>
            </div>
            
            <div class="space-y-3 text-sm text-gray-700">
                <p><strong class="inline-block w-10 text-gray-900 bg-gray-100 text-center rounded">AW</strong> = Stok Awal / SIV</p>
                <p><strong class="inline-block w-10 text-gray-900 bg-gray-100 text-center rounded">TB</strong> = Tambah Stok</p>
                <p><strong class="inline-block w-10 text-gray-900 bg-gray-100 text-center rounded">TTL</strong> = Total Stok Sebelum Penjualan</p>
                <p><strong class="inline-block w-10 text-red-700 bg-red-100 text-center rounded">AH</strong> = Total Stok Setelah Penjualan / Tutup Buku</p>
                <p><strong class="inline-block w-10 text-blue-700 bg-blue-100 text-center rounded">TR</strong> = Stok Awal dikurangi stok akhir, menjadi penjualan (Terjual)</p>
                <p><strong class="inline-block w-10 text-green-700 bg-green-100 text-center rounded">H</strong> = Harga Jual</p>
                <p><strong class="inline-block w-10 text-green-700 bg-green-100 text-center rounded">JML</strong> = Hasil Kali Penjualan Dan Harga (Total)</p>
            </div>

            <div class="mt-6 pt-4 border-t text-right">
                <button onclick="tutupModalBantuan()" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded text-sm font-bold shadow transition">Tutup Panduan</button>
            </div>
        </div>
    </div>

    <!-- MODAL EDIT TRANSAKSI -->
    <div id="modalEdit" class="fixed inset-0 bg-black/60 hidden flex items-center justify-center z-50">
        <div class="bg-white p-6 rounded-lg w-96 shadow-2xl">
            <h2 class="text-lg font-bold mb-4 text-gray-800 border-b pb-2">Edit Transaksi</h2>
            <form action="/edit-transaksi" method="POST" class="space-y-4">
                <input type="hidden" name="id" id="editId">
                <div>
                    <label class="block text-xs font-medium text-gray-500 mb-1">Nama Produk</label>
                    <input type="text" id="editProduk" disabled class="w-full p-2 border rounded bg-gray-100 text-sm font-semibold text-gray-600">
                </div>
                <div class="grid grid-cols-3 gap-3">
                    <div>
                        <label class="block text-xs font-bold text-blue-600 mb-1">Awal (AW)</label>
                        <input type="number" name="aw" id="editAw" class="w-full p-2 border rounded text-sm bg-yellow-50" required>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-600 mb-1">Tambah (TB)</label>
                        <input type="number" name="tb" id="editTb" class="w-full p-2 border rounded text-sm" required>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-red-600 mb-1">Sisa (AH)</label>
                        <input type="number" name="ah" id="editAh" class="w-full p-2 border rounded text-sm bg-red-50" required>
                    </div>
                </div>
                <div class="flex justify-end gap-2 mt-6 pt-4 border-t">
                    <button type="button" onclick="tutupModalEdit()" class="bg-gray-400 hover:bg-gray-500 text-white px-4 py-2 rounded text-sm">Batal</button>
                    <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 font-bold text-white px-4 py-2 rounded text-sm">Simpan Perubahan</button>
                </div>
            </form>
        </div>
    </div>
    <!-- MODAL INFO KUNCI BUKU -->
    <div id="modalInfoBuku" class="fixed inset-0 bg-black/60 hidden flex items-center justify-center z-50">
        <div class="bg-white p-6 rounded-lg w-[400px] shadow-2xl">
            <h2 class="text-lg font-bold text-red-700 mb-3 border-b pb-2">Apa itu Kunci Buku?</h2>
            <div class="text-sm text-gray-600 space-y-3">
                <p>Fitur ini digunakan untuk <strong>mengamankan data</strong> transaksi Anda setelah laporan bulanan selesai.</p>
                <ul class="list-disc ml-4 space-y-1">
                    <li>Transaksi yang sudah dikunci <strong>tidak bisa diedit atau dihapus</strong>.</li>
                    <li>Ini mencegah perubahan data yang tidak sengaja terjadi di masa lalu.</li>
                    <li>Gunakan fitur ini hanya jika Anda sudah yakin semua data transaksi dalam bulan tersebut sudah benar.</li>
                </ul>
            </div>
            <div class="mt-6 pt-4 border-t text-right">
                <button onclick="tutupModalInfoBuku()" class="bg-gray-600 hover:bg-gray-700 text-white px-5 py-2 rounded text-sm font-bold">Mengerti</button>
            </div>
        </div>
    </div>
    <script>
        const masterStok = JSON.parse(`<%- JSON.stringify(masterStok || {}) %>`);
        const produkSelect = document.getElementById('produkSelect');
        const stokAwalInput = document.getElementById('stokAwalInput');

        function updateStokAwalOtomatis() {
            const produkTerpilih = produkSelect.value;
            stokAwalInput.value = (masterStok && masterStok[produkTerpilih] !== undefined) ? masterStok[produkTerpilih] : 0;
        }
        produkSelect.addEventListener('change', updateStokAwalOtomatis);
        window.addEventListener('DOMContentLoaded', updateStokAwalOtomatis);

        async function hapusKatalog(kategori, brand, produkString) {
            if (confirm(`Hapus "${produkString}" dari katalog?`)) {
                const response = await fetch('/katalog/hapus', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ kategori, brand, produkString })
                });
                if ((await response.json()).success) window.location.reload();
            }
        }

        // LOGIKA MODAL KATALOG
        const modalKatalog = document.getElementById('modalKatalog');
        function bukaModalKatalog() {
            modalKatalog.classList.remove('hidden');
        }
        function tutupModalKatalog() {
            modalKatalog.classList.add('hidden');
        }

        // LOGIKA MODAL BANTUAN
        const modalBantuan = document.getElementById('modalBantuan');
        function bukaModalBantuan() {
            modalBantuan.classList.remove('hidden');
        }
        function tutupModalBantuan() {
            modalBantuan.classList.add('hidden');
        }

        // LOGIKA MODAL EDIT
        const modalEdit = document.getElementById('modalEdit');
        function bukaModalEdit(id, produk, aw, tb, ah) {
            document.getElementById('editId').value = id;
            document.getElementById('editProduk').value = produk;
            document.getElementById('editAw').value = aw;
            document.getElementById('editTb').value = tb;
            document.getElementById('editAh').value = ah;
            modalEdit.classList.remove('hidden');
        }
        function tutupModalEdit() {
            modalEdit.classList.add('hidden');
        }

        async function hapusTransaksi(id) {
            if (confirm("Apakah Anda yakin ingin menghapus data penjualan ini secara permanen?")) {
                const response = await fetch('/hapus-transaksi', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id })
                });
                if ((await response.json()).success) window.location.reload();
            }
        }
        // Fungsi untuk Modal Info Buku
        const modalInfoBuku = document.getElementById('modalInfoBuku');
        function bukaModalInfoBuku() {
            modalInfoBuku.classList.remove('hidden');
        }
        function tutupModalInfoBuku() {
            modalInfoBuku.classList.add('hidden');
        }
    </script>
</body>
</html>